# Maintainer: Styly

pkgname=k3code
pkgver=0.0.22
pkgrel=3
pkgdesc='k3Code desktop app, a vendored t3code fork'
url='https://t3.codes'
arch=('x86_64')
license=('MIT')
depends=(
  'alsa-lib'
  'at-spi2-core'
  'cairo'
  'dbus'
  'expat'
  'gcc-libs'
  'gdk-pixbuf2'
  'glib2'
  'gtk3'
  'hicolor-icon-theme'
  'libcups'
  'libdrm'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxext'
  'libxfixes'
  'libxkbcommon'
  'libxrandr'
  'mesa'
  'nspr'
  'nss'
  'pango'
  'systemd-libs'
  'xdg-utils'
  'zlib'
)
makedepends=(
  'bun'
  'git'
  'python'
  'rsync'
)
optdepends=(
  'openai-codex: use the system-installed Codex CLI'
)
provides=("t3code-bin=${pkgver}")
conflicts=('t3code-bin')
options=('!debug' '!emptydirs' '!strip')
source=()
sha256sums=()

_setup_build_env() {
  export CI=1
  export HOME="$srcdir/home"
  export XDG_CACHE_HOME="$srcdir/cache"
  export npm_config_cache="$srcdir/npm-cache"
  export ELECTRON_CACHE="$srcdir/electron-cache"
  export ELECTRON_BUILDER_CACHE="$srcdir/electron-builder-cache"

  install -d "$HOME" "$XDG_CACHE_HOME" "$npm_config_cache" "$ELECTRON_CACHE" "$ELECTRON_BUILDER_CACHE"
}

prepare() {
  rm -rf "$srcdir/upstream" "$srcdir/artifacts" "$srcdir/squashfs-root"
  cp -a "$startdir/upstream" "$srcdir/upstream"
  chmod -R u+rwX "$srcdir/upstream"

  cd "$srcdir/upstream"
  _setup_build_env
  bun install --frozen-lockfile
}

build() {
  cd "$srcdir/upstream"
  _setup_build_env

  node scripts/build-desktop-artifact.ts \
    --platform linux \
    --target AppImage \
    --arch x64 \
    --build-version "$pkgver" \
    --output-dir "$srcdir/artifacts"

  local appimage_path
  appimage_path="$(find "$srcdir/artifacts" -maxdepth 1 -type f -name "T3-Code-${pkgver}-*.AppImage" | sort | head -n 1)"

  if [[ -z "$appimage_path" || ! -f "$appimage_path" ]]; then
    echo "Expected AppImage artifact not found in $srcdir/artifacts" >&2
    return 1
  fi

  chmod +x "$appimage_path"

  (
    cd "$srcdir"
    "$appimage_path" --appimage-extract >/dev/null
  )

  if [[ ! -d "$srcdir/squashfs-root" ]]; then
    echo "Failed to extract AppImage payload." >&2
    return 1
  fi
}

package() {
  install -d "$pkgdir/opt/$pkgname"
  cp -a --no-preserve=ownership "$srcdir/squashfs-root/." "$pkgdir/opt/$pkgname/"

  chmod -R a+rX "$pkgdir/opt/$pkgname"

  if [[ -x "$pkgdir/opt/$pkgname/k3code" && ! -e "$pkgdir/opt/$pkgname/k3-code-desktop" ]]; then
    ln -s k3code "$pkgdir/opt/$pkgname/k3-code-desktop"
  fi

  install -Dm755 /dev/stdin "$pkgdir/usr/bin/k3code" << 'EOF'
#!/usr/bin/env bash
set -euo pipefail

appdir='/opt/k3code'
export APPDIR="$appdir"

if [[ -z "${CODEX_CLI_PATH-}" ]] && command -v codex >/dev/null 2>&1; then
  export CODEX_CLI_PATH="$(command -v codex)"
fi

export PATH="$appdir:$appdir/usr/sbin:$PATH"
export XDG_DATA_DIRS="$appdir/usr/share${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"
export GSETTINGS_SCHEMA_DIR="$appdir/usr/share/glib-2.0/schemas${GSETTINGS_SCHEMA_DIR:+:$GSETTINGS_SCHEMA_DIR}"

extra_flags=()
if [[ -n "${WAYLAND_DISPLAY-}" || "${XDG_SESSION_TYPE-}" == "wayland" ]]; then
  extra_flags+=(--enable-features=UseOzonePlatform --ozone-platform=wayland --ozone-platform-hint=wayland)
else
  extra_flags+=(--ozone-platform-hint=auto)
fi

exec "$appdir/t3code" --no-sandbox "${extra_flags[@]}" "$@"
EOF

  ln -s k3code "$pkgdit3usr/bin/k3-code-desktop"

  install -Dm644 "$srcdir/upstream/assets/prod/black-universal-1024.png" \
    "$pkgdir/usr/share/icons/hicolor/1024x1024/apps/k3-code-desktop.png"
  ln -s k3-code-desktop.png \
    "$pkgdir/usr/share/icons/hicolor/1024x1024/apps/k3code.png"
  install -Dm644 "$srcdir/upstream/assets/prod/black-universal-1024.png" \
    "$pkgdir/usr/share/pixmaps/k3-code-desktop.png"
  ln -s k3-code-desktop.png "$pkgdir/usr/share/pixmaps/k3code.png"

  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/k3-code-desktop.desktop" << 'EOF'
[Desktop Entry]
Name=k3 Code
Comment=k3 Code desktop build
Exec=k3code %U
Terminal=false
Type=Application
Icon=k3code
StartupWMClass=k3code
Categories=Development;
EOF

  install -Dm644 "$srcdir/upstream/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
